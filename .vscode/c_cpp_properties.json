{
  "version": 4,
  "configurations": [
    {
      "name": "Causal-SysTrace (macOS / Cursor)",
      "includePath": [
        "${workspaceFolder}/build",
        "${workspaceFolder}/third_party/ide",
        "${workspaceFolder}/third_party/libbpf/include",
        "${workspaceFolder}/**"
      ],
      "defines": [],
      "macFrameworkPath": [],
      "compilerPath": "/usr/bin/clang",
      "cStandard": "c17",
      "cppStandard": "c++17",
      "intelliSenseMode": "macos-clang-arm64",
      "compileCommands": "${workspaceFolder}/compile_commands.json"
    },
    {
      "name": "Causal-SysTrace (Linux VM)",
      "includePath": [
        "${workspaceFolder}/build",
        "${workspaceFolder}/third_party/ide",
        "${workspaceFolder}/third_party/libbpf/include",
        "/usr/include",
        "/usr/include/bpf",
        "${workspaceFolder}/**"
      ],
      "defines": [],
      "compilerPath": "/usr/bin/gcc",
      "cStandard": "c17",
      "cppStandard": "c++17",
      "intelliSenseMode": "linux-gcc-x64",
      "compileCommands": "${workspaceFolder}/compile_commands.json"
    }
  ]
}
